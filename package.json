{
  "name": "admin-cli",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "admin-cli": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "lint": "eslint src",
    "check:esm": "grep -R \\\"require(\\\" src && echo '❌ CommonJS detected' && exit 1 || echo '✅ ESM clean'",
    "generate:report": "node scripts/generate-migration-report.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "eslint": "^10.0.2",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1"
  }
}
